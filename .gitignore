# Secrets and sensitive files
*.pem
*.key
id_rsa
id_ed25519
*.p12
*.pfx
.env
.env.*
secrets/
private/

# SSH private keys (public keys are fine)
ssh/id_*
!ssh/id_*.pub

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Vim swap/backup files
*.swp
*.swo
*~
.netrwhist

# Editor directories
.idea/
.vscode/

# Local machine overrides (not shared)
shell/.bashrc.local
shell/.zshrc.local
git/.gitconfig.local

# Claude Code: never commit credentials or session/conversation data
claude/.credentials.json
claude/.claude.json
claude/projects/
claude/sessions/
claude/todos/
claude/history.jsonl
claude/shell-snapshots/
claude/cache/
claude/paste-cache/
claude/file-history/
claude/telemetry/
claude/statsig/
claude/backups/
claude/debug/
claude/ide/
claude/session-env/
claude/plugins/
claude/downloads/
claude/agent-memory/
claude/stats-cache.json
claude/mcp-needs-auth-cache.json
