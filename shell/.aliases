# ~/.aliases - shared aliases sourced by both bash and zsh
# Organized by category

# ── Navigation ────────────────────────────────────────────────────────────────
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
alias ~='cd ~'

# ── Listing ───────────────────────────────────────────────────────────────────
alias ls='ls --color=auto'          # colorized output
alias ll='ls -lh'                   # long format, human-readable sizes
alias la='ls -lha'                  # long format + hidden files
alias lt='ls -lht'                  # sort by modification time

# macOS ls doesn't support --color=auto; use -G instead
if [[ "$(uname)" == "Darwin" ]]; then
    alias ls='ls -G'
fi

# Use eza/exa if available (modern ls replacement)
if command -v eza &>/dev/null; then
    alias ls='eza --icons'
    alias ll='eza -lh --icons --git'
    alias la='eza -lha --icons --git'
    alias lt='eza -lh --icons --sort=modified'
    alias tree='eza --tree --icons'
fi

# ── File operations ───────────────────────────────────────────────────────────
alias cp='cp -iv'                   # interactive, verbose
alias mv='mv -iv'                   # interactive, verbose
alias rm='rm -iv'                   # interactive, verbose (avoid accidents)
alias mkdir='mkdir -pv'             # create parents, verbose

# ── Searching ─────────────────────────────────────────────────────────────────
alias grep='grep --color=auto'
alias fgrep='fgrep --color=auto'
alias egrep='egrep --color=auto'

# fd: modern find replacement (package is fd-find on Debian/Ubuntu)
if command -v fdfind &>/dev/null && ! command -v fd &>/dev/null; then
    alias fd='fdfind'
fi

# ── Git shortcuts ─────────────────────────────────────────────────────────────
alias g='git'
alias gs='git status -sb'           # short branch + status
alias ga='git add'
alias gaa='git add -A'
alias gc='git commit'
alias gcm='git commit -m'
alias gp='git push'
alias gpl='git pull'
alias gco='git checkout'
alias gcb='git checkout -b'
alias gd='git diff'
alias gds='git diff --staged'
alias gl='git lg'                   # pretty log (defined in .gitconfig)
alias glog='git log --oneline --graph --all'
alias gst='git stash'
alias gstp='git stash pop'

# ── Docker shortcuts ──────────────────────────────────────────────────────────
alias d='docker'
alias dc='docker compose'
alias dps='docker ps --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}"'
alias dpsa='docker ps -a --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}"'
alias dimg='docker images'
alias dlogs='docker logs -f'        # follow logs: dlogs <container>
alias dexec='docker exec -it'       # shell into container: dexec <container> bash
alias dprune='docker system prune -f'

# ── Networking ────────────────────────────────────────────────────────────────
alias myip='curl -s https://ifconfig.me && echo'
alias localip='ip -br addr show | grep -v "^lo"'  # Linux; see below for macOS
if [[ "$(uname)" == "Darwin" ]]; then
    alias localip='ifconfig | grep "inet " | grep -v 127.0.0.1'
fi
alias ports='ss -tlnp'              # listening TCP ports (Linux)
if [[ "$(uname)" == "Darwin" ]]; then
    alias ports='lsof -iTCP -sTCP:LISTEN -n -P'
fi

# ── System ────────────────────────────────────────────────────────────────────
alias top='htop'                    # use htop if installed
alias df='df -h'                    # human-readable disk usage
alias du='du -sh'                   # summarized, human-readable
alias path='echo $PATH | tr ":" "\n"'  # print PATH entries one per line
alias reload='source ~/.bashrc 2>/dev/null || source ~/.zshrc'

# ── Python ────────────────────────────────────────────────────────────────────
alias py='python3'
alias pip='pip3'
alias venv='python3 -m venv .venv && source .venv/bin/activate'
alias activate='source .venv/bin/activate'

# ── Node ──────────────────────────────────────────────────────────────────────
alias ni='npm install'
alias nid='npm install --save-dev'
alias nr='npm run'
alias nrs='npm run start'
alias nrt='npm run test'

# ── Misc ──────────────────────────────────────────────────────────────────────
alias c='clear'
alias h='history'
alias hg='history | grep'          # search history: hg <term>
alias week='date +%V'              # current ISO week number
alias timestamp='date +%Y%m%d_%H%M%S'
alias json='python3 -m json.tool'  # pretty-print JSON: cat file.json | json
alias watch='watch -n1'            # default 1s refresh
